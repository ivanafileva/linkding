# Copy this file to .env and fill in your values before running docker compose up.
# .env is gitignored — never commit it.

# PostgreSQL credentials (used by both the db and linkding services)
POSTGRES_DB=linkding
POSTGRES_USER=linkding
POSTGRES_PASSWORD=changeme

# Linkding admin account created on first startup
LD_SUPERUSER_NAME=admin
LD_SUPERUSER_PASSWORD=changeme
